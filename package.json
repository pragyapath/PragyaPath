{
  "name": "pragya-path",
  "version": "1.0.0",
  "description": "Pragya Path – Hatha Yoga & Sound Healing website",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "build": "npm run build:css",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:css\"",
    "dev:server": "nodemon -e js,ejs server.js",
    "build:css": "tailwindcss -i ./public/css/input.css -o ./public/css/output.css --minify",
    "dev:css": "tailwindcss -i ./public/css/input.css -o ./public/css/output.css --watch",
    "test": "jest"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "fs-extra": "^11.2.0",
    "helmet": "^7.1.0",
    "resend": "^6.12.3"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "connect-livereload": "^0.6.1",
    "jest": "^29.7.0",
    "livereload": "^0.10.3",
    "nodemon": "^3.1.4",
    "tailwindcss": "^3.4.4"
  },
  "keywords": [
    "yoga",
    "sound healing",
    "bhaktapur",
    "nepal"
  ],
  "author": "Pragya Path",
  "license": "ISC"
}
