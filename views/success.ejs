<%- include('partials/head') %>
<%- include('partials/nav') %>
<meta http-equiv="refresh" content="8;url=/">

<main class="min-h-screen flex items-center justify-center px-6 py-16 bg-stone">
  <div class="max-w-md w-full text-center fade-up visible">

    <!-- Icon -->
    <div class="w-16 h-16 rounded-full bg-sage/10 flex items-center justify-center mx-auto mb-8">
      <svg class="w-7 h-7 text-sage" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7"/>
      </svg>
    </div>

    <p class="section-label mb-4">Message Received</p>
    <h1 class="font-serif text-4xl font-medium text-ink mb-5">Thank you</h1>
    <p class="font-sans text-muted font-light leading-relaxed text-[15px] mb-10">
      Namaste. We have received your message and will get back to you within 24 hours.
    </p>

    <a href="/"
       class="inline-flex items-center gap-2 bg-terra text-base text-[11px] font-sans font-semibold uppercase tracking-widest2 px-8 py-4 rounded-full hover:bg-surface hover:text-stone transition-colors duration-300">
      Back to Home
    </a>

    <p class="mt-8 text-[10px] font-sans text-muted/50 uppercase tracking-widest2">Redirecting in 8 seconds</p>
  </div>
</main>

<%- include('partials/footer') %>
