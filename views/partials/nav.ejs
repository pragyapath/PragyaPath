        <path d="M30 6 C38 6 50 20 50 32 C50 44 30 54 30 54 C30 54 10 44 10 32 C10 20 22 6 30 6Z"
              fill="currentColor" opacity="0.15"/>
        <path d="M30 6 C38 6 50 20 50 32 C50 44 30 54 30 54 C30 54 10 44 10 32 C10 20 22 6 30 6Z"
