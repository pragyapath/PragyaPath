    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-10" role="list">
      <li><a href="#services" class="nav-link relative text-[11px] font-sans font-medium uppercase tracking-widest2 opacity-70 hover:opacity-100 transition-opacity duration-200 after:content-[''] after:absolute after:-bottom-2 after:left-0 after:w-0 after:h-px after:bg-current after:transition-all after:duration-300 hover:after:w-full">Services</a></li>
      <li><a href="#about" class="nav-link relative text-[11px] font-sans font-medium uppercase tracking-widest2 opacity-70 hover:opacity-100 transition-opacity duration-200 after:content-[''] after:absolute after:-bottom-2 after:left-0 after:w-0 after:h-px after:bg-current after:transition-all after:duration-300 hover:after:w-full">About</a></li>
      <li><a href="#gallery" class="nav-link relative text-[11px] font-sans font-medium uppercase tracking-widest2 opacity-70 hover:opacity-100 transition-opacity duration-200 after:content-[''] after:absolute after:-bottom-2 after:left-0 after:w-0 after:h-px after:bg-current after:transition-all after:duration-300 hover:after:w-full">Gallery</a></li>
      <li><a href="#pricing" class="nav-link relative text-[11px] font-sans font-medium uppercase tracking-widest2 opacity-70 hover:opacity-100 transition-opacity duration-200 after:content-[''] after:absolute after:-bottom-2 after:left-0 after:w-0 after:h-px after:bg-current after:transition-all after:duration-300 hover:after:w-full">Pricing</a></li>
      <li><a href="#contact" class="nav-link relative text-[11px] font-sans font-medium uppercase tracking-widest2 opacity-70 hover:opacity-100 transition-opacity duration-200 after:content-[''] after:absolute after:-bottom-2 after:left-0 after:w-0 after:h-px after:bg-current after:transition-all after:duration-300 hover:after:w-full">Contact</a></li>
    </ul>

    <!-- Mobile toggle -->
    <button id="nav-toggle" aria-label="Open menu" aria-expanded="false"
            class="md:hidden w-8 h-8 flex flex-col justify-center gap-[5px] group">
      <span class="nav-bar block h-px w-full bg-current transition-all duration-300 origin-center"></span>
      <span class="nav-bar block h-px w-5 bg-current transition-all duration-300 ml-auto"></span>
    </button>
  </div>
</nav>

<!-- Mobile drawer -->
<div id="nav-drawer"
     class="fixed inset-0 z-40 bg-base flex flex-col items-center justify-center
            opacity-0 pointer-events-none transition-all duration-500 backdrop-blur-3xl"
     role="dialog" aria-modal="true" aria-label="Navigation menu">

  <button id="nav-close" aria-label="Close menu"
          class="absolute top-6 right-6 p-2 rounded-full bg-line text-stone hover:bg-gold hover:text-base transition-all duration-300 transform hover:scale-110">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  </button>

  <nav class="flex flex-col items-center gap-8 w-full px-6" aria-label="Mobile links">
    <a href="/"        class="drawer-link text-4xl md:text-5xl font-serif font-light text-stone hover:text-gold transition-colors w-full text-center py-2 border-b border-line/50">Home</a>
    <a href="#services" class="drawer-link text-4xl md:text-5xl font-serif font-light text-stone hover:text-gold transition-colors w-full text-center py-2 border-b border-line/50">Services</a>
    <a href="#about"    class="drawer-link text-4xl md:text-5xl font-serif font-light text-stone hover:text-gold transition-colors w-full text-center py-2 border-b border-line/50">About</a>
    <a href="#gallery"  class="drawer-link text-4xl md:text-5xl font-serif font-light text-stone hover:text-gold transition-colors w-full text-center py-2 border-b border-line/50">Gallery</a>
    <a href="#pricing"  class="drawer-link text-4xl md:text-5xl font-serif font-light text-stone hover:text-gold transition-colors w-full text-center py-2 border-b border-line/50">Pricing</a>
    <a href="#contact"  class="drawer-link text-4xl md:text-5xl font-serif font-light text-stone hover:text-gold transition-colors w-full text-center py-2">Contact</a>
  </nav>
</div>

<script>
(function () {
  const nav      = document.getElementById('nav');
  const toggle   = document.getElementById('nav-toggle');
  const drawer   = document.getElementById('nav-drawer');
  const closeBtn = document.getElementById('nav-close');
  const links    = document.querySelectorAll('.drawer-link');
  const logoName = document.getElementById('nav-logo-name');
  const logoSub  = document.getElementById('nav-logo-sub');

  /* ── Scroll state ── */
  function onScroll() {
    if (window.scrollY > 40) {
      nav.classList.add('bg-surface/95', 'backdrop-blur-xl', 'border-line', 'shadow-2xl');
      nav.classList.remove('bg-base/50', 'backdrop-blur-md', 'border-line/50', 'py-4');
    } else {
      nav.classList.remove('bg-surface/95', 'backdrop-blur-xl', 'border-line', 'shadow-2xl');
      nav.classList.add('bg-base/50', 'backdrop-blur-md', 'border-line/50', 'py-4');
    }
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  /* ── Mobile drawer ── */
  function open() {
    drawer.classList.remove('opacity-0', 'pointer-events-none');
    drawer.classList.add('opacity-100');
    document.body.style.overflow = 'hidden';
    toggle.setAttribute('aria-expanded', 'true');
  }
  function close() {
    drawer.classList.add('opacity-0', 'pointer-events-none');
    drawer.classList.remove('opacity-100');
    document.body.style.overflow = '';
    toggle.setAttribute('aria-expanded', 'false');
  }

  toggle.addEventListener('click', open);
  closeBtn.addEventListener('click', close);
  links.forEach(l => l.addEventListener('click', close));
  document.addEventListener('keydown', e => { if (e.key === 'Escape') close(); });
})();
</script>
