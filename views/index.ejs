        <div class="grid grid-cols-1 sm:grid-cols-2 gap-10">
          <div>
            <label for="name" class="block text-[10px] font-sans font-bold uppercase tracking-widest3 text-gold mb-2">Name *</label>
            <input
              type="text" id="name" name="name"
              value="<%= values.name || '' %>"
