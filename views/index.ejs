<!-- Hiking Interactive Script (Playable Mini-Game) -->
<script>
  (function() {
    const canvas = document.getElementById('hiking-canvas');
    if(!canvas) return;
    const ctx = canvas.getContext('2d');
    let w, h;
    
    // Game state
    let scrollX = 0;
    let targetScrollX = 0;
    
    // Physics / Jumping
    let hikerYOffset = 0;
    let hikerVY = 0;
    let isJumping = false;
    const gravity = 0.6;
    const jumpPower = -11;
    
    // Game mechanics
    let score = 0;
    let rocks = [];
    let nextRockX = 600;
    let gameState = 'playing'; // 'playing', 'hit'
    let hitTimer = 0;
    
    // Colors matching palette
    const COLOR_SKY = '#F4F9F9';
    const COLOR_SUN = '#EE7924';
    const COLOR_MOUNTAIN_FAR = '#8BD3DD';
    const COLOR_MOUNTAIN_MID = '#1A6A73';
    const COLOR_MOUNTAIN_NEAR = '#0F383D';
    
    function resize() {
      w = canvas.parentElement.clientWidth;
      h = canvas.parentElement.clientHeight;
      canvas.width = w * window.devicePixelRatio;
      canvas.height = h * window.devicePixelRatio;
      ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
    }
    
    window.addEventListener('resize', resize);
    setTimeout(resize, 100);
    
    // Controls: Any click/tap makes the hiker jump
    const jump = (e) => {
      e.preventDefault(); 
      if(!isJumping) {
        isJumping = true;
        hikerVY = jumpPower;
        if(gameState === 'hit') gameState = 'playing';
      }
    };
    
    canvas.addEventListener('mousedown', jump);
    canvas.addEventListener('touchstart', jump, {passive: false});
    // Remove pointer-events from canvas temporarily if user wants to scroll past it, 
    // but the aspect ratio requires them to touch it. 
    // We only prevent default on the canvas itself, so scrolling outside works.
    
    // Terrain math (reused for drawing and collision)
    function getTerrainY(worldX, yBase, amplitude, frequency) {
      const noise = Math.sin(worldX * frequency) * amplitude 
                  + Math.cos(worldX * frequency * 2.5) * (amplitude * 0.3);
      return yBase - noise;
    }
    
    // Draw mountain layer
    function drawMountains(offset, yBase, amplitude, frequency, color) {
      ctx.fillStyle = color;
      ctx.beginPath();
      ctx.moveTo(0, h);
      for(let x = 0; x <= w; x += 10) {
        ctx.lineTo(x, getTerrainY(x + offset, yBase, amplitude, frequency));
      }
      ctx.lineTo(w, h);
      ctx.fill();
    }
    
    // Draw Hiker
    let stepCycle = 0;
    function drawHiker(x, baseY) {
      ctx.save();
      ctx.translate(x, baseY + hikerYOffset);
      
      // Stop walking animation if jumping or hit
      if(!isJumping && gameState !== 'hit') {
        stepCycle += 0.2;
      }
      
      const bob = isJumping ? -2 : Math.sin(stepCycle * 2) * 2;
      
      ctx.fillStyle = gameState === 'hit' ? '#FF5555' : COLOR_SUN;
      
      // Torso/Backpack
      ctx.beginPath();
      ctx.roundRect(-4, bob - 16, 8, 16, 3);
      ctx.fill();
      
      // Head
      ctx.beginPath();
      ctx.arc(0, bob - 24, 6, 0, Math.PI*2);
      ctx.fill();
      
      // Backpack detailing
      ctx.fillStyle = COLOR_MOUNTAIN_NEAR;
      ctx.beginPath();
      ctx.roundRect(-7, bob - 14, 5, 12, 2); 
      ctx.fill();
      
      // Legs
      ctx.strokeStyle = gameState === 'hit' ? '#FF5555' : COLOR_SUN;
      ctx.lineWidth = 3;
      ctx.lineCap = 'round';
      
      // Left leg
      ctx.beginPath();
      ctx.moveTo(-1, bob);
      ctx.lineTo(isJumping ? -4 : -2 + Math.sin(stepCycle) * 8, bob + 12);
      ctx.stroke();
      
      // Right leg
      ctx.beginPath();
      ctx.moveTo(2, bob);
      ctx.lineTo(isJumping ? 4 : 2 + Math.sin(stepCycle + Math.PI) * 8, bob + 12);
      ctx.stroke();
      
      // Hiking stick (hide if hit)
      if (gameState !== 'hit') {
        ctx.strokeStyle = COLOR_MOUNTAIN_NEAR;
        ctx.lineWidth = 2;
        ctx.beginPath();
        ctx.moveTo(8, bob - 5);
        ctx.lineTo(12 + Math.sin(stepCycle + Math.PI) * 5, bob + 14);
        ctx.stroke();
      }
      
      ctx.restore();
    }
    
    // Draw obstacles (rocks)
    function drawRocks(terrainParams) {
      ctx.fillStyle = COLOR_MOUNTAIN_NEAR;
      for (let i = rocks.length - 1; i >= 0; i--) {
        const r = rocks[i];
        const screenX = r.x - scrollX;
        
        // Remove offscreen
        if (screenX < -50) {
          rocks.splice(i, 1);
          continue;
        }
        
        // Draw if on screen
        if (screenX < w + 50) {
          const terrainY = getTerrainY(r.x, ...terrainParams);
          
          ctx.beginPath();
          // Draw a jagged rock shape
          ctx.moveTo(screenX - 10, terrainY);
          ctx.lineTo(screenX - 5, terrainY - 15);
          ctx.lineTo(screenX + 5, terrainY - 18);
          ctx.lineTo(screenX + 12, terrainY - 10);
          ctx.lineTo(screenX + 15, terrainY);
          ctx.fill();
          
          // Collision Check
          const hikerScreenX = w / 2;
          if (!r.passed && screenX > hikerScreenX - 15 && screenX < hikerScreenX + 15) {
             // Hiker is over the rock X-wise. Check Y-wise.
             if (hikerYOffset > -15) { // Collided!
                gameState = 'hit';
                hitTimer = 30;
                score = Math.max(0, score - 5);
                r.passed = true;
             } else {
                // Successfully jumped over!
                score += 10;
                r.passed = true;
             }
          }
        }
      }
    }
    
    function loop() {
      // Auto run
      const speed = gameState === 'hit' ? 0.5 : 3.5;
      targetScrollX += speed;
      scrollX += (targetScrollX - scrollX) * 0.2;
      
      // Generate new rocks
      if (scrollX + w > nextRockX) {
        rocks.push({ x: nextRockX, passed: false });
        nextRockX += 300 + Math.random() * 400; // random gap between 300-700px
      }
      
      // Physics (Gravity & Jumping)
      if(isJumping) {
        hikerVY += gravity;
        hikerYOffset += hikerVY;
        if(hikerYOffset >= 0) {
          hikerYOffset = 0;
          hikerVY = 0;
          isJumping = false;
        }
      }
      
      // Hit flash logic
      if (hitTimer > 0) hitTimer--;
      if (hitTimer === 0 && gameState === 'hit') gameState = 'playing';
      
      // Background / Sky
      ctx.fillStyle = hitTimer > 0 && hitTimer % 4 < 2 ? '#FFDDDD' : COLOR_SKY;
      ctx.fillRect(0, 0, w, h);
      
      // Sun
      ctx.fillStyle = COLOR_SUN;
      ctx.beginPath();
      ctx.arc(w * 0.7 - (scrollX * 0.02), h * 0.25, w * 0.1, 0, Math.PI*2);
      ctx.fill();
      
      // Parallax Layers
      drawMountains(scrollX * 0.3, h * 0.45, h * 0.15, 0.004, COLOR_MOUNTAIN_FAR);
      drawMountains(scrollX * 0.6, h * 0.65, h * 0.12, 0.007, COLOR_MOUNTAIN_MID);
      
      // Foreground Layer Params
      const fgParams = [h * 0.85, h * 0.08, 0.012];
      drawMountains(scrollX, fgParams[0], fgParams[1], fgParams[2], COLOR_MOUNTAIN_NEAR);
      
      // Obstacles
      drawRocks(fgParams);
      
      // Get exact Y position of foreground at center of screen for the hiker to stand on
      const hikerTerrainY = getTerrainY(scrollX + w/2, fgParams[0], fgParams[1], fgParams[2]);
      drawHiker(w/2, hikerTerrainY);
      
      // UI / Text
      ctx.fillStyle = COLOR_MOUNTAIN_NEAR;
      ctx.font = '800 16px Montserrat, sans-serif';
      ctx.textAlign = 'left';
      ctx.fillText(`Zen Points: ${score}`, 20, 30);
      
      ctx.fillStyle = COLOR_SKY;
      ctx.font = '600 12px Montserrat, sans-serif';
      ctx.textAlign = 'center';
      ctx.globalAlpha = 0.9;
      // letterSpacing hack for canvas
      const text = "TAP TO JUMP";
      ctx.fillText(text, w/2, h - 20);
      ctx.globalAlpha = 1.0;
      
      requestAnimationFrame(loop);
    }
    
    loop();
  })();
</script>


